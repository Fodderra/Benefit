# Sanity CMS — create your project at https://sanity.io
# Copy this file to .env.local and fill in your real values
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production

# Revalidation webhook secret — set the same value in Vercel env vars
# and in your Sanity webhook URL: https://your-site.vercel.app/api/revalidate?secret=YOUR_SECRET
SANITY_REVALIDATE_SECRET=your-secret-here
